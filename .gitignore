# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.yarn/*
!.yarn/patches
!.yarn/releases
vite.config.ts.*

# Aztec (Noir) build outputs
packages/contracts/aztec/noir/target
packages/contracts/aztec/noir/artifacts
packages/contracts/aztec/dist

# Ethereum (Foundry) build outputs
packages/contracts/ethereum/solidity/out
packages/contracts/ethereum/solidity/cache
packages/contracts/ethereum/solidity/broadcast
packages/contracts/ethereum/solidity/lib
packages/contracts/ethereum/generated
packages/contracts/ethereum/dist

# Playwright / e2e outputs
e2e/playwright-report
e2e/html-report
e2e/test-results
e2e/.cache

# Per-run state dirs generated by test / dev-setup scripts (contains
# private keys, never commit).
.state/
**/.state/

# Per-app e2e runtime state (generated by deploy fixture)
apps/*/.e2e

# Local-network configs are generated per-developer and per-run. Checked-in
# JSONs live alongside these for public networks (testnet, devnet, nextnet).
apps/*/src/config/networks/local.json

# FPC admin backups (contain real admin secret keys — never commit)
apps/fpc-operator/backups/

# TypeScript build cache
*.tsbuildinfo

# Turbo
.turbo
codegenCache.json
