{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "composite": true,
    "noEmit": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@gregojuice/embedded-wallet/ui": ["../embedded-wallet/src/ui.ts"],
      "@gregojuice/embedded-wallet": ["../embedded-wallet/src/index.ts"],
      "@gregojuice/common": ["../common/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts*", "scripts/**/*.ts", "../contracts/artifacts/**/*.ts", "../embedded-wallet/src/**/*.ts*", "../common/src/**/*.ts"]
}
