{
  "name": "@gregojuice/aztec",
  "version": "0.0.18",
  "type": "module",
  "main": "dist/lib/subscription-fpc.js",
  "types": "dist/lib/subscription-fpc.d.ts",
  "exports": {
    "./subscription-fpc": {
      "types": "./dist/lib/subscription-fpc.d.ts",
      "import": "./dist/lib/subscription-fpc.js"
    },
    "./fpc-gas-constants": {
      "types": "./dist/lib/fpc-gas-constants.d.ts",
      "import": "./dist/lib/fpc-gas-constants.js"
    },
    "./artifacts/*": {
      "types": "./dist/noir/artifacts/*.d.ts",
      "import": "./dist/noir/artifacts/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf ./dist ./noir/artifacts ./noir/target",
    "compile": "cd noir && aztec compile",
    "codegen": "cd noir && aztec codegen ./target -o artifacts",
    "build": "yarn compile && yarn codegen && tsc -p tsconfig.build.json && mkdir -p dist/noir/target && cp noir/target/*.json dist/noir/target/",
    "build:codegen": "yarn codegen",
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "yarn build:ts"
  },
  "dependencies": {
    "@aztec/aztec.js": "v4.3.0-nightly.20260417",
    "@aztec/foundation": "v4.3.0-nightly.20260417",
    "@aztec/stdlib": "v4.3.0-nightly.20260417",
    "@aztec/wallets": "v4.3.0-nightly.20260417"
  },
  "devDependencies": {
    "@aztec/accounts": "v4.3.0-nightly.20260417",
    "@aztec/constants": "v4.3.0-nightly.20260417",
    "@aztec/entrypoints": "v4.3.0-nightly.20260417",
    "@aztec/ethereum": "v4.3.0-nightly.20260417",
    "@aztec/noir-contracts.js": "v4.3.0-nightly.20260417",
    "typescript": "~5.7.3",
    "vitest": "^3"
  }
}
