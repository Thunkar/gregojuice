    "@aztec/ethereum": "v4.2.0-nightly.20260323",
    "@aztec/foundation": "v4.2.0-nightly.20260323",
    "@aztec/noir-contracts.js": "v4.2.0-nightly.20260323",
    "@aztec/stdlib": "v4.2.0-nightly.20260323",
    "@aztec/wallets": "v4.2.0-nightly.20260323",
    "@gregojuice/embedded-wallet": "workspace:*",
    "typescript": "~5.7.3",
    "vitest": "^3"
  }
