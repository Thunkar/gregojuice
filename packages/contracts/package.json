{
  "name": "@gregojuice/contracts",
  "version": "0.0.13",
  "type": "module",
  "main": "dist/src/subscription-fpc.js",
  "types": "dist/src/subscription-fpc.d.ts",
  "exports": {
    "./subscription-fpc": {
      "types": "./dist/src/subscription-fpc.d.ts",
      "import": "./dist/src/subscription-fpc.js"
    },
    "./fpc-gas-constants": {
      "types": "./dist/src/fpc-gas-constants.d.ts",
      "import": "./dist/src/fpc-gas-constants.js"
    },
    "./artifacts/*": {
      "types": "./dist/artifacts/*.d.ts",
      "import": "./dist/artifacts/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf ./dist ./artifacts ./*/target",
    "compile": "aztec compile",
    "codegen": "aztec codegen ./target -o artifacts",
    "build": "yarn compile && yarn codegen && tsc -p tsconfig.build.json && mkdir -p dist/target && cp target/*.json dist/target/",
    "build:codegen": "yarn codegen",
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "yarn build:ts",
    "forge:build": "cd bridge && forge build",
    "forge:deploy": "cd bridge && forge script script/Deploy.s.sol --rpc-url ${L1_RPC_URL:-https://ethereum-sepolia-rpc.publicnode.com} --private-key $PRIVATE_KEY --broadcast",
    "forge:artifacts": "cd bridge && ./generate-artifacts.sh"
  },
  "dependencies": {
    "@aztec/aztec.js": "v4.2.0-nightly.20260410",
    "@aztec/foundation": "v4.2.0-nightly.20260410",
    "@aztec/stdlib": "v4.2.0-nightly.20260410",
    "@aztec/wallets": "v4.2.0-nightly.20260410"
  },
  "devDependencies": {
    "@aztec/accounts": "v4.2.0-nightly.20260410",
    "@aztec/constants": "v4.2.0-nightly.20260410",
    "@aztec/entrypoints": "v4.2.0-nightly.20260410",
    "@aztec/ethereum": "v4.2.0-nightly.20260410",
    "@aztec/noir-contracts.js": "v4.2.0-nightly.20260410",
    "typescript": "~5.7.3",
    "vitest": "^3"
  }
}
