{
  "name": "@aztec-kit/swap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist .tsbuildinfo",
    "dev": "NODE_OPTIONS=--max_http_header_size=128000 vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "preview": "NODE_OPTIONS=--max_http_header_size=128000 vite preview",
    "deploy-admin:local": "node --experimental-transform-types scripts/deploy-admin.ts --network local",
    "deploy-admin:testnet": "node --experimental-transform-types scripts/deploy-admin.ts --network testnet",
    "deploy:local": "node --experimental-transform-types scripts/deploy.ts --network local",
    "deploy:testnet": "node --experimental-transform-types scripts/deploy.ts --network testnet",
    "register-fpc-signups:local": "node --experimental-transform-types scripts/register-fpc-signups.ts --network local",
    "register-fpc-signups:testnet": "node --experimental-transform-types scripts/register-fpc-signups.ts --network testnet",
    "mint:local": "node --experimental-transform-types scripts/mint.ts --network local",
    "mint:testnet": "node --experimental-transform-types scripts/mint.ts --network testnet"
  },
  "dependencies": {
    "@aztec-kit/common": "workspace:*",
    "@aztec-kit/contracts-aztec": "workspace:*",
    "@aztec-kit/embedded-wallet": "workspace:*",
    "@aztec/accounts": "v4.3.0-nightly.20260504",
    "@aztec/aztec.js": "v4.3.0-nightly.20260504",
    "@aztec/constants": "v4.3.0-nightly.20260504",
    "@aztec/entrypoints": "v4.3.0-nightly.20260504",
    "@aztec/ethereum": "v4.3.0-nightly.20260504",
    "@aztec/foundation": "v4.3.0-nightly.20260504",
    "@aztec/noir-contracts.js": "v4.3.0-nightly.20260504",
    "@aztec/protocol-contracts": "v4.3.0-nightly.20260504",
    "@aztec/pxe": "v4.3.0-nightly.20260504",
    "@aztec/stdlib": "v4.3.0-nightly.20260504",
    "@aztec/wallet-sdk": "v4.3.0-nightly.20260504",
    "@aztec/wallets": "v4.3.0-nightly.20260504",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.1",
    "@mui/material": "^6.3.1",
    "@mui/styles": "^6.3.1",
    "buffer-json": "^2.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "zod": "^3.23.8",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@aztec/aztec": "v4.3.0-nightly.20260504",
    "@types/buffer-json": "^2",
    "@types/node": "^22.15.17",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.7.3",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "^0.26.0"
  }
}
