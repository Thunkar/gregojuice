{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "composite": true,
    "noEmit": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@gregojuice/embedded-wallet/ui": ["../../packages/embedded-wallet/src/ui.ts"],
      "@gregojuice/embedded-wallet": ["../../packages/embedded-wallet/src/index.ts"],
      "@gregojuice/common/ui": ["../../packages/common/src/ui.ts"],
      "@gregojuice/common": ["../../packages/common/src/index.ts"],
      "@gregojuice/aztec/*": ["../../packages/contracts/aztec/lib/*"],
      "@gregojuice/aztec/artifacts/*": ["../../packages/contracts/aztec/noir/artifacts/*"]
    }
  },
  "include": [
    "src/**/*.ts*",
    "../../packages/contracts/aztec/noir/artifacts/**/*.ts",
    "../../packages/contracts/aztec/lib/**/*.ts",
    "../../packages/embedded-wallet/src/**/*.ts*",
    "../../packages/common/src/**/*.ts",
    "../../packages/common/src/**/*.tsx"
  ]
}
