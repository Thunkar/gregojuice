{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "composite": true,
    "noEmit": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@gregojuice/embedded-wallet/ui": ["../../packages/embedded-wallet/src/ui.ts"],
      "@gregojuice/embedded-wallet": ["../../packages/embedded-wallet/src/index.ts"],
      "@gregojuice/common": ["../../packages/common/src/index.ts"],
      "@gregojuice/ethereum": ["../../packages/ethereum/generated/bridge-contract-artifacts.ts"]
    }
  },
  "include": [
    "src/**/*.ts*",
    "scripts/**/*.ts",
    "../../packages/embedded-wallet/src/**/*.ts*",
    "../../packages/common/src/**/*.ts",
    "../../packages/ethereum/generated/**/*.ts"
  ]
}
